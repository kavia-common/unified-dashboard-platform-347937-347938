# Backend
# Comma-separated list of allowed frontend origins (no trailing slash), e.g.:
# BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-frontend.example.com
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (preferred single URL)
# Use the SAME DATABASE_URL value as the DB container (fitness_db) so backend and migrate.sh agree.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Firebase Admin SDK
# Provide either path to a service account JSON file:
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=/path/to/firebase-service-account.json
# ...or the JSON itself (stringified). If both are set, *_JSON is preferred.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
